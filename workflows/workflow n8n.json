    {
      "parameters": {
        "jsCode": "const entrada = $('Webhook (recibe consulta)1').first().json.body || {};\nconst nombre = entrada.nombre || 'IA';\nconst j = $input.first().json || {};\n\nconst texto = j?.choices?.[0]?.message?.content;\nif (texto) {\n  return [{ json: { modelo: nombre, texto, ok: true } }];\n}\n\nlet motivo = 'Sin respuesta.';\nif (j?.error?.message) motivo = 'Sin respuesta: ' + j.error.message;\nelse if (j?.message) motivo = 'Sin respuesta: ' + j.message;\nelse if (j?.error) motivo = 'Sin respuesta: ' + JSON.stringify(j.error);\nreturn [{ json: { modelo: nombre, texto: motivo, ok: false } }];"
      },
