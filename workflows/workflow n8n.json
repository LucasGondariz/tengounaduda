    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "html-field-0001",
              "name": "html",
              "type": "string",
              "value": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Panel de 4 IAs</title>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;450;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n  :root{\n    --ink:#1b1916;\n    --ink-soft:#5c554c;\n    --ink-faint:#928a7d;\n    --paper:#f3efe7;\n    --paper-2:#ebe5d9;\n    --card:#fffdf8;\n    --line:#ddd5c6;\n    --line-strong:#cfc6b4;\n\n    --c1:#d97706;\n    --c2:#2563eb;\n    --c3:#dc2626;\n    --c4:#7c3aed;\n\n    --shadow:0 1px 0 rgba(27,25,22,.04), 0 18px 40px -24px rgba(27,25,22,.35);\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;padding:0}\n  body{\n    background:\n      radial-gradient(1200px 600px at 50% -10%, rgba(255,255,255,.7), transparent 60%),\n      var(--paper);\n    color:var(--ink);\n    font-family:\"IBM Plex Sans\", system-ui, sans-serif;\n    font-weight:450;\n    line-height:1.55;\n    -webkit-font-smoothing:antialiased;\n    text-rendering:optimizeLegibility;\n    min-height:100vh;\n  }\n  .wrap{max-width:1120px;margin:0 auto;padding:48px 24px 96px}\n\n  /* ---------- Header ---------- */\n  header{margin-bottom:28px}\n  .kicker{\n    display:inline-flex;align-items:center;gap:9px;\n    font-family:\"IBM Plex Mono\",monospace;\n    font-size:12px;letter-spacing:.18em;text-transform:uppercase;\n    color:var(--ink-soft);\n    padding:7px 12px;border:1px solid var(--line-strong);border-radius:100px;\n    background:var(--card);\n  }\n  .kicker .dot{width:7px;height:7px;border-radius:50%;background:var(--c1);\n    box-shadow:11px 0 0 var(--c2), 22px 0 0 var(--c3), 33px 0 0 var(--c4);\n    margin-right:33px}\n  h1{\n    font-family:\"Bricolage Grotesque\", sans-serif;\n    font-weight:700;font-size:clamp(32px,5vw,54px);\n    line-height:1.16;letter-spacing:-.02em;margin:18px 0 10px;\n    max-width:18ch;text-wrap:balance;\n  }\n  h1 em{font-style:normal;position:relative;white-space:nowrap}\n  h1 em::after{content:\"\";position:absolute;left:0;right:0;bottom:-.02em;height:.16em;\n    background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3),var(--c4));\n    border-radius:4px;opacity:.9}\n  .sub{color:var(--ink-soft);font-size:17px;max-width:60ch;margin:0;text-wrap:pretty}\n\n  /* ---------- Composer ---------- */\n  .composer{\n    margin-top:30px;background:var(--card);border:1px solid var(--line);\n    border-radius:20px;box-shadow:var(--shadow);overflow:hidden;\n    transition:border-color .2s ease, box-shadow .2s ease;\n  }\n  .composer:focus-within{border-color:var(--line-strong);\n    box-shadow:0 1px 0 rgba(27,25,22,.04), 0 24px 50px -28px rgba(27,25,22,.45)}\n  textarea{\n    display:block;width:100%;border:0;outline:0;resize:vertical;\n    background:transparent;color:var(--ink);\n    font-family:inherit;font-size:18px;line-height:1.6;\n    padding:22px 24px 8px;min-height:104px;\n  }\n  textarea::placeholder{color:var(--ink-faint)}\n  .composer-bar{\n    display:flex;align-items:center;gap:14px;flex-wrap:wrap;\n    padding:12px 16px 14px 24px;border-top:1px solid var(--paper-2);\n  }\n  .hint{font-family:\"IBM Plex Mono\",monospace;font-size:12px;color:var(--ink-faint);\n    letter-spacing:.02em}\n  .hint b{color:var(--ink-soft);font-weight:500}\n  .spacer{flex:1 1 auto}\n  .send{\n    appearance:none;border:0;cursor:pointer;\n    display:inline-flex;align-items:center;gap:10px;\n    background:var(--ink);color:#fff;\n    font-family:inherit;font-weight:600;font-size:15px;\n    padding:12px 20px;border-radius:12px;\n    transition:transform .12s ease, background .2s ease, opacity .2s ease;\n  }\n  .send:hover{transform:translateY(-1px)}\n  .send:active{transform:translateY(0)}\n  .send:disabled{opacity:.45;cursor:not-allowed;transform:none}\n  .send svg{width:17px;height:17px}\n\n  /* ---------- Eleccion ---------- */\n  .eleccion{display:none;margin-top:18px;font-size:15px;color:var(--ink-soft)}\n  .eleccion.show{display:block}\n  .eleccion b{font-weight:600}\n\n  /* ---------- Results grid ---------- */\n  .grid{\n    margin-top:34px;display:grid;gap:18px;\n    grid-template-columns:repeat(2,minmax(0,1fr));\n  }\n  @media (max-width:760px){.grid{grid-template-columns:1fr}}\n\n  .panel{\n    --accent:var(--ink);\n    background:var(--card);border:1px solid var(--line);border-radius:18px;\n    box-shadow:var(--shadow);overflow:hidden;display:flex;flex-direction:column;\n    opacity:1;\n  }\n  @media (prefers-reduced-motion: no-preference){\n    .panel{animation:rise .5s cubic-bezier(.2,.7,.2,1) backwards}\n  }\n  @keyframes rise{from{transform:translateY(12px)}to{transform:none}}\n  .panel .top{\n    display:flex;align-items:center;gap:12px;\n    padding:15px 18px;border-bottom:1px solid var(--paper-2);\n    position:relative;\n  }\n  .panel .top::before{content:\"\";position:absolute;left:0;top:0;bottom:0;width:4px;\n    background:var(--accent)}\n  .badge{\n    width:38px;height:38px;border-radius:11px;flex:0 0 auto;\n    display:grid;place-items:center;color:#fff;font-family:\"Bricolage Grotesque\",sans-serif;\n    font-weight:700;font-size:17px;background:var(--accent);\n    box-shadow:inset 0 0 0 1px rgba(255,255,255,.18);\n  }\n  .meta{display:flex;flex-direction:column;line-height:1.2;min-width:0}\n  .meta .name{font-weight:600;font-size:15.5px;letter-spacing:-.01em;\n    white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n  .meta .tag{font-family:\"IBM Plex Mono\",monospace;font-size:11px;letter-spacing:.08em;\n    text-transform:uppercase;color:var(--accent);font-weight:500}\n  .idx{margin-left:auto;font-family:\"IBM Plex Mono\",monospace;font-size:12px;\n    color:var(--ink-faint);display:flex;align-items:center;gap:7px}\n\n  /* spinner por tarjeta mientras espera */\n  .spin{width:13px;height:13px;border-radius:50%;\n    border:2px solid var(--line-strong);border-top-color:var(--accent);\n    animation:rot .7s linear infinite}\n  @keyframes rot{to{transform:rotate(360deg)}}\n\n  .body{padding:18px 20px 14px;font-size:15.5px;color:#28241f;flex:1}\n  .body > :first-child{margin-top:0}\n  .body > :last-child{margin-bottom:0}\n  .body p{margin:0 0 .85em}\n  .body h1,.body h2,.body h3{font-family:\"Bricolage Grotesque\",sans-serif;\n    line-height:1.2;margin:1.1em 0 .45em;letter-spacing:-.01em}\n  .body h1{font-size:20px}.body h2{font-size:18px}.body h3{font-size:16px}\n  .body ul,.body ol{margin:.4em 0 .9em;padding-left:1.35em}\n  .body li{margin:.25em 0}\n  .body a{color:var(--accent);text-underline-offset:2px}\n  .body strong{font-weight:600;color:var(--ink)}\n  .body code{font-family:\"IBM Plex Mono\",monospace;font-size:.86em;\n    background:var(--paper-2);padding:.12em .4em;border-radius:5px}\n  .body pre{background:#211f1b;color:#f3efe7;border-radius:10px;padding:14px 16px;\n    overflow:auto;margin:.6em 0 1em}\n  .body pre code{background:transparent;padding:0;color:inherit;font-size:13px;line-height:1.6}\n  .body blockquote{margin:.6em 0;padding:.2em 0 .2em 14px;border-left:3px solid var(--line-strong);\n    color:var(--ink-soft)}\n  .body.err{color:var(--c3)}\n\n  /* ---------- Foot / elegir esta IA ---------- */\n  .foot{padding:0 20px 18px;margin-top:auto}\n  .pick{\n    appearance:none;cursor:pointer;background:transparent;color:var(--ink-soft);\n    font-family:\"IBM Plex Mono\",monospace;font-size:12px;letter-spacing:.06em;\n    border:1px solid var(--line-strong);border-radius:10px;padding:9px 14px;\n    display:inline-flex;align-items:center;gap:8px;\n    transition:color .18s ease, border-color .18s ease, background .18s ease;\n  }\n  .pick:hover{color:var(--accent);border-color:var(--accent)}\n  .pick:disabled{opacity:.4;cursor:not-allowed}\n  .pick svg{width:13px;height:13px}\n  .panel.chosen{border-color:var(--accent);\n    box-shadow:0 1px 0 rgba(27,25,22,.04), 0 0 0 1.5px var(--accent), 0 18px 40px -22px var(--accent)}\n  .panel.chosen .pick{background:var(--accent);color:#fff;border-color:var(--accent)}\n  .grid.has-choice .panel:not(.chosen){opacity:.5;transition:opacity .35s ease}\n  .grid.has-choice .panel:not(.chosen):hover{opacity:.85}\n\n  /* ---------- Skeleton ---------- */\n  .sk{height:11px;border-radius:6px;margin:0 0 11px;\n    background:linear-gradient(90deg,var(--paper-2),#f4eee2,var(--paper-2));\n    background-size:200% 100%;animation:sweep 1.3s infinite}\n  @keyframes sweep{0%{background-position:200% 0}100%{background-position:-200% 0}}\n\n  footer{margin-top:54px;padding-top:20px;border-top:1px solid var(--line);\n    display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;\n    font-family:\"IBM Plex Mono\",monospace;font-size:12px;color:var(--ink-faint);\n    letter-spacing:.02em}\n  footer a{color:var(--ink-soft);text-decoration:none}\n  footer a:hover{color:var(--ink)}\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <header>\n      <span class=\"kicker\"><span class=\"dot\"></span>Consult&aacute; &middot; 4 IAs</span>\n      <h1>&iquest;Ten&eacute;s una duda?<br>Eleg&iacute; con <em>qu&eacute; IA seguir</em></h1>\n      <p class=\"sub\">Tu consulta va a cuatro modelos a la vez. Eleg&iacute; una para seguir charlando en OpenRouter.</p>\n    </header>\n\n    <div class=\"composer\">\n      <textarea id=\"pregunta\" placeholder=\"Escribí tu consulta…\"></textarea>\n      <div class=\"composer-bar\">\n        <span class=\"hint\">Enviar con <b>Ctrl + Enter</b></span>\n        <span class=\"spacer\"></span>\n        <button class=\"send\" id=\"btn\" onclick=\"consultar()\">\n          <span id=\"btnLabel\">Consultar a las 4</span>\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M13 6l6 6-6 6\"/></svg>\n        </button>\n      </div>\n    </div>\n\n    <p class=\"eleccion\" id=\"eleccion\"></p>\n\n    <div class=\"grid\" id=\"resultados\"></div>\n\n    <footer>\n      <span>4 modelos &middot; respuestas en paralelo</span>\n      <span><a href=\"?demo=1\">ver demo</a> &middot; servido desde n8n</span>\n    </footer>\n  </div>\n\n<script>\n  /* ====== CONFIG: los 4 modelos. Cambia nombre/slug/color a gusto. ====== */\n  var MODELOS = [\n    { nombre:\"GLM 4.5 Air\",      slug:\"z-ai/glm-4.5-air:free\",                  color:\"#d97706\", mono:\"G\", tag:\"Z-AI\" },\n    { nombre:\"Nemotron 3 Super\", slug:\"nvidia/nemotron-3-super-120b-a12b:free\", color:\"#2563eb\", mono:\"N\", tag:\"NVIDIA\" },\n    { nombre:\"Laguna M.1\",       slug:\"poolside/laguna-m.1:free\",               color:\"#dc2626\", mono:\"L\", tag:\"Poolside\" },\n    { nombre:\"GPT-OSS 120B\",     slug:\"openai/gpt-oss-120b:free\",               color:\"#7c3aed\", mono:\"P\", tag:\"OpenAI\" }\n  ];\n  var ENDPOINT = (function(){\n    // Construye la URL absoluta del webhook a partir de la URL actual de la pagina.\n    // Sirve aunque el origin sea \"null\": usamos location.href como base.\n    try {\n      var base = location.href.split(\"/webhook/\")[0];\n      if (base && base.indexOf(\"http\") === 0) return base + \"/webhook/consulta\";\n    } catch(e){}\n    return \"/webhook/consulta\";\n  })();\n\n  var $ = function(id){ return document.getElementById(id); };\n  var pregunta = $(\"pregunta\"), cont = $(\"resultados\");\n  var btn = $(\"btn\"), btnLabel = $(\"btnLabel\");\n\n  pregunta.addEventListener(\"keydown\", function(e){\n    if((e.ctrlKey || e.metaKey) && e.key === \"Enter\"){ consultar(); }\n  });\n\n  function setLoading(on){\n    btn.disabled = on;\n    btnLabel.textContent = on ? \"Consultando...\" : \"Consultar a las 4\";\n  }\n\n  /* Crea las 4 tarjetas con spinner; cada una se rellena cuando llega su fetch */\n  function renderEsqueleto(){\n    cont.innerHTML = \"\";\n    cont.classList.remove(\"has-choice\");\n    $(\"eleccion\").className = \"eleccion\"; $(\"eleccion\").innerHTML = \"\";\n\n    MODELOS.forEach(function(m, i){\n      var card = document.createElement(\"div\");\n      card.className = \"panel\";\n      card.id = \"card-\" + i;\n      card.style.setProperty(\"--accent\", m.color);\n      card.style.animationDelay = (i*0.05) + \"s\";\n      card.innerHTML =\n        '<div class=\"top\">' +\n          '<div class=\"badge\">' + esc(m.mono) + '</div>' +\n          '<div class=\"meta\"><span class=\"name\">' + esc(m.nombre) + '</span>' +\n          '<span class=\"tag\">' + esc(m.tag) + '</span></div>' +\n          '<span class=\"idx\">0' + (i+1) + ' <span class=\"spin\"></span></span>' +\n        '</div>' +\n        '<div class=\"body\" id=\"body-' + i + '\">' +\n          '<div class=\"sk\" style=\"width:92%\"></div>' +\n          '<div class=\"sk\" style=\"width:100%\"></div>' +\n          '<div class=\"sk\" style=\"width:84%\"></div>' +\n          '<div class=\"sk\" style=\"width:70%\"></div>' +\n        '</div>' +\n        '<div class=\"foot\"><button class=\"pick\" data-modelo=\"' + esc(m.nombre) + '\" data-slug=\"' + esc(m.slug) + '\" disabled>' +\n          'Seguir con esta' +\n          '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M7 17L17 7M17 7H9M17 7v8\"/></svg>' +\n        '</button></div>';\n      cont.appendChild(card);\n    });\n  }\n\n  /* Rellena UNA tarjeta cuando su respuesta llega */\n  function pintarTarjeta(i, texto, esError){\n    var card = $(\"card-\" + i);\n    if(!card) return;\n    var spin = card.querySelector(\".spin\");\n    if(spin) spin.remove();\n    var body = $(\"body-\" + i);\n    body.className = \"body\" + (esError ? \" err\" : \"\");\n    body.innerHTML = esError ? esc(texto) : mdToHtml(texto || \"Sin respuesta.\");\n    var pick = card.querySelector(\".pick\");\n    if(pick && !esError) pick.disabled = false;\n  }\n\n  /* Una llamada por modelo. Devuelve siempre (resuelve aunque falle). */\n  function consultarModelo(m, i, q){\n    if(/[?&]demo=1/.test(location.search)){\n      var espera = [800, 5200, 1800, 9000][i] || 2000;\n      return new Promise(function(res){\n        setTimeout(function(){ pintarTarjeta(i, demoTexto(i), false); res(); }, espera);\n      });\n    }\n    return fetch(ENDPOINT, {\n      method:\"POST\",\n      body: JSON.stringify({ pregunta: q, slug: m.slug, nombre: m.nombre })\n    })\n    .then(function(r){\n      if(!r.ok) throw new Error(\"HTTP \" + r.status);\n      return r.json();\n    })\n    .then(function(data){\n      var ok = data && data.ok;\n      pintarTarjeta(i, (data && data.texto) || \"Sin respuesta.\", !ok);\n    })\n    .catch(function(e){\n      pintarTarjeta(i, \"Error: \" + e.message, true);\n    });\n  }\n\n  function consultar(){\n    var q = pregunta.value.trim();\n    if(!q){ pregunta.focus(); return; }\n\n    setLoading(true);\n    renderEsqueleto();\n\n    var todas = MODELOS.map(function(m, i){ return consultarModelo(m, i, q); });\n    Promise.all(todas).then(function(){ setLoading(false); });\n  }\n\n  /* Seguir con esta IA -> abre el chat de OpenRouter con ese modelo cargado */\n  cont.addEventListener(\"click\", function(e){\n    var p = e.target.closest(\".pick\");\n    if(!p || p.disabled) return;\n    var card = p.closest(\".panel\");\n    var modelo = p.getAttribute(\"data-modelo\");\n    var slug = p.getAttribute(\"data-slug\");\n    var color = card.style.getPropertyValue(\"--accent\");\n\n    /* marca visual de la tarjeta elegida */\n    cont.querySelectorAll(\".panel\").forEach(function(c){ c.classList.remove(\"chosen\"); });\n    card.classList.add(\"chosen\");\n    cont.classList.add(\"has-choice\");\n    $(\"eleccion\").className = \"eleccion show\";\n    $(\"eleccion\").innerHTML = 'Abriendo <b style=\"color:' + color + '\">' + esc(modelo) + '</b> en OpenRouter...';\n\n    /* redireccion: nueva pestania al chat de OpenRouter con ese modelo */\n    var url = \"https://openrouter.ai/chat?models=\" + encodeURIComponent(slug);\n    window.open(url, \"_blank\", \"noopener\");\n  });\n\n  /* ---------- utilidades ---------- */\n  function esc(s){\n    return String(s)\n      .replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\")\n      .replace(/\"/g,\"&quot;\");\n  }\n\n  function mdToHtml(src){\n    var BT = String.fromCharCode(96);\n    var text = String(src).replace(/\\r\\n/g,\"\\n\");\n    var fence = BT+BT+BT;\n    var parts = text.split(fence);\n    var html = \"\";\n    for(var i=0;i<parts.length;i++){\n      if(i % 2 === 1){\n        var code = parts[i].replace(/^[^\\n]*\\n/, \"\");\n        html += \"<pre><code>\" + esc(code.replace(/\\n$/,\"\")) + \"</code></pre>\";\n      } else {\n        html += renderInlineBlocks(parts[i], BT);\n      }\n    }\n    return html;\n  }\n\n  function renderInlineBlocks(block, BT){\n    var lines = block.split(\"\\n\");\n    var out = \"\", list = null, para = [];\n    function flushPara(){\n      if(para.length){ out += \"<p>\" + inline(para.join(\" \"), BT) + \"</p>\"; para = []; }\n    }\n    function closeList(){ if(list){ out += \"</\" + list + \">\"; list = null; } }\n    for(var i=0;i<lines.length;i++){\n      var t = lines[i].trim();\n      if(t === \"\"){ flushPara(); closeList(); continue; }\n      var h = t.match(/^(#{1,3})\\s+(.*)$/);\n      if(h){ flushPara(); closeList();\n        var lvl = h[1].length; out += \"<h\"+lvl+\">\" + inline(h[2],BT) + \"</h\"+lvl+\">\"; continue; }\n      if(/^>\\s?/.test(t)){ flushPara(); closeList();\n        out += \"<blockquote>\" + inline(t.replace(/^>\\s?/,\"\"),BT) + \"</blockquote>\"; continue; }\n      var ul = t.match(/^[-*]\\s+(.*)$/);\n      var ol = t.match(/^\\d+[.)]\\s+(.*)$/);\n      if(ul || ol){\n        flushPara();\n        var want = ul ? \"ul\" : \"ol\";\n        if(list !== want){ closeList(); list = want; out += \"<\"+want+\">\"; }\n        out += \"<li>\" + inline((ul?ul[1]:ol[1]),BT) + \"</li>\";\n        continue;\n      }\n      closeList();\n      para.push(t);\n    }\n    flushPara(); closeList();\n    return out;\n  }\n\n  function inline(s, BT){\n    var out = esc(s);\n    var codeRe = new RegExp(BT + \"([^\" + BT + \"]+)\" + BT, \"g\");\n    out = out.replace(codeRe, function(_,c){ return \"<code>\" + c + \"</code>\"; });\n    out = out.replace(/\\*\\*([^*]+)\\*\\*/g, \"<strong>$1</strong>\");\n    out = out.replace(/\\*([^*]+)\\*/g, \"<em>$1</em>\");\n    out = out.replace(/__([^_]+)__/g, \"<strong>$1</strong>\");\n    out = out.replace(/\\[([^\\]]+)\\]\\((https?:[^)]+)\\)/g,\n      '<a href=\"$2\" target=\"_blank\" rel=\"noopener\">$1</a>');\n    return out;\n  }\n\n  /* ---------- demo ---------- */\n  function demoTexto(i){\n    return [\n      \"Respuesta rapida. Mi recomendacion:\\n\\n- **Empeza simple** y ajusta despues.\\n- Pensa en el *costo de oportunidad*.\",\n      \"### Analisis\\nTres dimensiones:\\n\\n1. Tiempo\\n2. Presupuesto\\n3. Riesgo\\n\\nSi priorizas velocidad, opcion A.\",\n      \"Lo veo asi:\\n\\n> No existe respuesta perfecta, existe la mejor decision con lo que sabes hoy.\",\n      \"Enfoque tecnico:\\n\\n- Ventaja: control.\\n- Desventaja: menos flexibilidad.\\n\\nMedi resultados con datos.\"\n    ][i] || \"Respuesta de ejemplo.\";\n  }\n</script>\n</body>\n</html>\n"
            }
          ]
        },
        "options": {}
      },
