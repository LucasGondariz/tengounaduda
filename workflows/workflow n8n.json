    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "html-field-0001",
              "name": "html",
              "type": "string",
              "value": "<!DOCTYPE html> <html lang=\"es\"> <head> <meta charset=\"utf-8\"> <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"> <title>Panel de 4 IAs</title> <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"> <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin> <link href=\"https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;450;500;600&display=swap\" rel=\"stylesheet\"> <style>   :root{     --ink:#1b1916;     --ink-soft:#5c554c;     --ink-faint:#928a7d;     --paper:#f3efe7;     --paper-2:#ebe5d9;     --card:#fffdf8;     --line:#ddd5c6;     --line-strong:#cfc6b4;      --c1:#d97706;     --c2:#2563eb;     --c3:#dc2626;     --c4:#7c3aed;      --shadow:0 1px 0 rgba(27,25,22,.04), 0 18px 40px -24px rgba(27,25,22,.35);   }   *{box-sizing:border-box}   html,body{margin:0;padding:0}   body{     background:       radial-gradient(1200px 600px at 50% -10%, rgba(255,255,255,.7), transparent 60%),       var(--paper);     color:var(--ink);     font-family:\"IBM Plex Sans\", system-ui, sans-serif;     font-weight:450;     line-height:1.55;     -webkit-font-smoothing:antialiased;     text-rendering:optimizeLegibility;     min-height:100vh;   }   .wrap{max-width:1120px;margin:0 auto;padding:48px 24px 96px}    /* ---------- Header ---------- */   header{margin-bottom:28px}   .kicker{     display:inline-flex;align-items:center;gap:9px;     font-family:\"IBM Plex Mono\",monospace;     font-size:12px;letter-spacing:.18em;text-transform:uppercase;     color:var(--ink-soft);     padding:7px 12px;border:1px solid var(--line-strong);border-radius:100px;     background:var(--card);   }   .kicker .dot{width:7px;height:7px;border-radius:50%;background:var(--c1);     box-shadow:11px 0 0 var(--c2), 22px 0 0 var(--c3), 33px 0 0 var(--c4);     margin-right:33px}   h1{     font-family:\"Bricolage Grotesque\", sans-serif;     font-weight:700;font-size:clamp(32px,5vw,54px);     line-height:1.16;letter-spacing:-.02em;margin:18px 0 10px;     max-width:18ch;text-wrap:balance;   }   h1 em{font-style:normal;position:relative;white-space:nowrap}   h1 em::after{content:\"\";position:absolute;left:0;right:0;bottom:-.02em;height:.16em;     background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3),var(--c4));     border-radius:4px;opacity:.9}   .sub{color:var(--ink-soft);font-size:17px;max-width:60ch;margin:0;text-wrap:pretty}    /* ---------- Composer ---------- */   .composer{     margin-top:30px;background:var(--card);border:1px solid var(--line);     border-radius:20px;box-shadow:var(--shadow);overflow:hidden;     transition:border-color .2s ease, box-shadow .2s ease;   }   .composer:focus-within{border-color:var(--line-strong);     box-shadow:0 1px 0 rgba(27,25,22,.04), 0 24px 50px -28px rgba(27,25,22,.45)}   textarea{     display:block;width:100%;border:0;outline:0;resize:vertical;     background:transparent;color:var(--ink);     font-family:inherit;font-size:18px;line-height:1.6;     padding:22px 24px 8px;min-height:104px;   }   textarea::placeholder{color:var(--ink-faint)}   .composer-bar{     display:flex;align-items:center;gap:14px;flex-wrap:wrap;     padding:12px 16px 14px 24px;border-top:1px solid var(--paper-2);   }   .hint{font-family:\"IBM Plex Mono\",monospace;font-size:12px;color:var(--ink-faint);     letter-spacing:.02em}   .hint b{color:var(--ink-soft);font-weight:500}   .spacer{flex:1 1 auto}   .send{     appearance:none;border:0;cursor:pointer;     display:inline-flex;align-items:center;gap:10px;     background:var(--ink);color:#fff;     font-family:inherit;font-weight:600;font-size:15px;     padding:12px 20px;border-radius:12px;     transition:transform .12s ease, background .2s ease, opacity .2s ease;   }   .send:hover{transform:translateY(-1px)}   .send:active{transform:translateY(0)}   .send:disabled{opacity:.45;cursor:not-allowed;transform:none}   .send svg{width:17px;height:17px}    /* ---------- Eleccion ---------- */   .eleccion{display:none;margin-top:18px;font-size:15px;color:var(--ink-soft)}   .eleccion.show{display:block}   .eleccion b{font-weight:600}    /* ---------- Results grid ---------- */   .grid{     margin-top:34px;display:grid;gap:18px;     grid-template-columns:repeat(2,minmax(0,1fr));   }   @media (max-width:760px){.grid{grid-template-columns:1fr}}    .panel{     --accent:var(--ink);     background:var(--card);border:1px solid var(--line);border-radius:18px;     box-shadow:var(--shadow);overflow:hidden;display:flex;flex-direction:column;     opacity:1;   }   @media (prefers-reduced-motion: no-preference){     .panel{animation:rise .5s cubic-bezier(.2,.7,.2,1) backwards}   }   @keyframes rise{from{transform:translateY(12px)}to{transform:none}}   .panel .top{     display:flex;align-items:center;gap:12px;     padding:15px 18px;border-bottom:1px solid var(--paper-2);     position:relative;   }   .panel .top::before{content:\"\";position:absolute;left:0;top:0;bottom:0;width:4px;     background:var(--accent)}   .badge{     width:38px;height:38px;border-radius:11px;flex:0 0 auto;     display:grid;place-items:center;color:#fff;font-family:\"Bricolage Grotesque\",sans-serif;     font-weight:700;font-size:17px;background:var(--accent);     box-shadow:inset 0 0 0 1px rgba(255,255,255,.18);   }   .meta{display:flex;flex-direction:column;line-height:1.2;min-width:0}   .meta .name{font-weight:600;font-size:15.5px;letter-spacing:-.01em;     white-space:nowrap;overflow:hidden;text-overflow:ellipsis}   .meta .tag{font-family:\"IBM Plex Mono\",monospace;font-size:11px;letter-spacing:.08em;     text-transform:uppercase;color:var(--accent);font-weight:500}   .idx{margin-left:auto;font-family:\"IBM Plex Mono\",monospace;font-size:12px;     color:var(--ink-faint);display:flex;align-items:center;gap:7px}    /* spinner por tarjeta mientras espera */   .spin{width:13px;height:13px;border-radius:50%;     border:2px solid var(--line-strong);border-top-color:var(--accent);     animation:rot .7s linear infinite}   @keyframes rot{to{transform:rotate(360deg)}}    .body{padding:18px 20px 14px;font-size:15.5px;color:#28241f;flex:1}   .body > :first-child{margin-top:0}   .body > :last-child{margin-bottom:0}   .body p{margin:0 0 .85em}   .body h1,.body h2,.body h3{font-family:\"Bricolage Grotesque\",sans-serif;     line-height:1.2;margin:1.1em 0 .45em;letter-spacing:-.01em}   .body h1{font-size:20px}.body h2{font-size:18px}.body h3{font-size:16px}   .body ul,.body ol{margin:.4em 0 .9em;padding-left:1.35em}   .body li{margin:.25em 0}   .body a{color:var(--accent);text-underline-offset:2px}   .body strong{font-weight:600;color:var(--ink)}   .body code{font-family:\"IBM Plex Mono\",monospace;font-size:.86em;     background:var(--paper-2);padding:.12em .4em;border-radius:5px}   .body pre{background:#211f1b;color:#f3efe7;border-radius:10px;padding:14px 16px;     overflow:auto;margin:.6em 0 1em}   .body pre code{background:transparent;padding:0;color:inherit;font-size:13px;line-height:1.6}   .body blockquote{margin:.6em 0;padding:.2em 0 .2em 14px;border-left:3px solid var(--line-strong);     color:var(--ink-soft)}   .body.err{color:var(--c3)}    /* ---------- Foot / elegir esta IA ---------- */   .foot{padding:0 20px 18px;margin-top:auto}   .pick{     appearance:none;cursor:pointer;background:transparent;color:var(--ink-soft);     font-family:\"IBM Plex Mono\",monospace;font-size:12px;letter-spacing:.06em;     border:1px solid var(--line-strong);border-radius:10px;padding:9px 14px;     display:inline-flex;align-items:center;gap:8px;     transition:color .18s ease, border-color .18s ease, background .18s ease;   }   .pick:hover{color:var(--accent);border-color:var(--accent)}   .pick:disabled{opacity:.4;cursor:not-allowed}   .pick svg{width:13px;height:13px}   .panel.chosen{border-color:var(--accent);     box-shadow:0 1px 0 rgba(27,25,22,.04), 0 0 0 1.5px var(--accent), 0 18px 40px -22px var(--accent)}   .panel.chosen .pick{background:var(--accent);color:#fff;border-color:var(--accent)}   .grid.has-choice .panel:not(.chosen){opacity:.5;transition:opacity .35s ease}   .grid.has-choice .panel:not(.chosen):hover{opacity:.85}    /* ---------- Skeleton ---------- */   .sk{height:11px;border-radius:6px;margin:0 0 11px;     background:linear-gradient(90deg,var(--paper-2),#f4eee2,var(--paper-2));     background-size:200% 100%;animation:sweep 1.3s infinite}   @keyframes sweep{0%{background-position:200% 0}100%{background-position:-200% 0}}    footer{margin-top:54px;padding-top:20px;border-top:1px solid var(--line);     display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;     font-family:\"IBM Plex Mono\",monospace;font-size:12px;color:var(--ink-faint);     letter-spacing:.02em}   footer a{color:var(--ink-soft);text-decoration:none}   footer a:hover{color:var(--ink)} </style> </head> <body>   <div class=\"wrap\">     <header>       <span class=\"kicker\"><span class=\"dot\"></span>Consult&aacute; &middot; 4 IAs</span>       <h1>&iquest;Ten&eacute;s una duda?<br>Eleg&iacute; con <em>qu&eacute; IA seguir</em></h1>       <p class=\"sub\">Tu consulta va a cuatro modelos a la vez. Eleg&iacute; una para seguir charlando en OpenRouter.</p>     </header>      <div class=\"composer\">       <textarea id=\"pregunta\" placeholder=\"Escribí tu consulta…\"></textarea>       <div class=\"composer-bar\">         <span class=\"hint\">Enviar con <b>Ctrl + Enter</b></span>         <span class=\"spacer\"></span>         <button class=\"send\" id=\"btn\" onclick=\"consultar()\">           <span id=\"btnLabel\">Consultar a las 4</span>           <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M13 6l6 6-6 6\"/></svg>         </button>       </div>     </div>      <p class=\"eleccion\" id=\"eleccion\"></p>      <div class=\"grid\" id=\"resultados\"></div>      <footer>       <span>4 modelos &middot; respuestas en paralelo</span>       <span><a href=\"?demo=1\">ver demo</a> &middot; servido desde n8n</span>     </footer>   </div>  <script>   /* ====== CONFIG: los 4 modelos. Cambia nombre/slug/color a gusto. ====== */   var MODELOS = [     { nombre:\"GLM 4.5 Air\",      slug:\"z-ai/glm-4.5-air:free\",                  color:\"#d97706\", mono:\"G\", tag:\"Z-AI\" },     { nombre:\"Nemotron 3 Super\", slug:\"nvidia/nemotron-3-super-120b-a12b:free\", color:\"#2563eb\", mono:\"N\", tag:\"NVIDIA\" },     { nombre:\"Laguna M.1\",       slug:\"poolside/laguna-m.1:free\",               color:\"#dc2626\", mono:\"L\", tag:\"Poolside\" },     { nombre:\"GPT-OSS 120B\",     slug:\"openai/gpt-oss-120b:free\",               color:\"#7c3aed\", mono:\"P\", tag:\"OpenAI\" }   ];   var ENDPOINT = \"/webhook/consulta\";    var $ = function(id){ return document.getElementById(id); };   var pregunta = $(\"pregunta\"), cont = $(\"resultados\");   var btn = $(\"btn\"), btnLabel = $(\"btnLabel\");    pregunta.addEventListener(\"keydown\", function(e){     if((e.ctrlKey || e.metaKey) && e.key === \"Enter\"){ consultar(); }   });    function setLoading(on){     btn.disabled = on;     btnLabel.textContent = on ? \"Consultando...\" : \"Consultar a las 4\";   }    /* Crea las 4 tarjetas con spinner; cada una se rellena cuando llega su fetch */   function renderEsqueleto(){     cont.innerHTML = \"\";     cont.classList.remove(\"has-choice\");     $(\"eleccion\").className = \"eleccion\"; $(\"eleccion\").innerHTML = \"\";      MODELOS.forEach(function(m, i){       var card = document.createElement(\"div\");       card.className = \"panel\";       card.id = \"card-\" + i;       card.style.setProperty(\"--accent\", m.color);       card.style.animationDelay = (i*0.05) + \"s\";       card.innerHTML =         '<div class=\"top\">' +           '<div class=\"badge\">' + esc(m.mono) + '</div>' +           '<div class=\"meta\"><span class=\"name\">' + esc(m.nombre) + '</span>' +           '<span class=\"tag\">' + esc(m.tag) + '</span></div>' +           '<span class=\"idx\">0' + (i+1) + ' <span class=\"spin\"></span></span>' +         '</div>' +         '<div class=\"body\" id=\"body-' + i + '\">' +           '<div class=\"sk\" style=\"width:92%\"></div>' +           '<div class=\"sk\" style=\"width:100%\"></div>' +           '<div class=\"sk\" style=\"width:84%\"></div>' +           '<div class=\"sk\" style=\"width:70%\"></div>' +         '</div>' +         '<div class=\"foot\"><button class=\"pick\" data-modelo=\"' + esc(m.nombre) + '\" data-slug=\"' + esc(m.slug) + '\" disabled>' +           'Seguir con esta' +           '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M7 17L17 7M17 7H9M17 7v8\"/></svg>' +         '</button></div>';       cont.appendChild(card);     });   }    /* Rellena UNA tarjeta cuando su respuesta llega */   function pintarTarjeta(i, texto, esError){     var card = $(\"card-\" + i);     if(!card) return;     var spin = card.querySelector(\".spin\");     if(spin) spin.remove();     var body = $(\"body-\" + i);     body.className = \"body\" + (esError ? \" err\" : \"\");     body.innerHTML = esError ? esc(texto) : mdToHtml(texto || \"Sin respuesta.\");     var pick = card.querySelector(\".pick\");     if(pick && !esError) pick.disabled = false;   }    /* Una llamada por modelo. Devuelve siempre (resuelve aunque falle). */   function consultarModelo(m, i, q){     if(/[?&]demo=1/.test(location.search)){       var espera = [800, 5200, 1800, 9000][i] || 2000;       return new Promise(function(res){         setTimeout(function(){ pintarTarjeta(i, demoTexto(i), false); res(); }, espera);       });     }     return fetch(ENDPOINT, {       method:\"POST\",       headers:{ \"Content-Type\":\"application/json\" },       body: JSON.stringify({ pregunta: q, slug: m.slug, nombre: m.nombre })     })     .then(function(r){       if(!r.ok) throw new Error(\"HTTP \" + r.status);       return r.json();     })     .then(function(data){       var ok = data && data.ok;       pintarTarjeta(i, (data && data.texto) || \"Sin respuesta.\", !ok);     })     .catch(function(e){       pintarTarjeta(i, \"Error: \" + e.message, true);     });   }    function consultar(){     var q = pregunta.value.trim();     if(!q){ pregunta.focus(); return; }      setLoading(true);     renderEsqueleto();      var todas = MODELOS.map(function(m, i){ return consultarModelo(m, i, q); });     Promise.all(todas).then(function(){ setLoading(false); });   }    /* Seguir con esta IA -> abre el chat de OpenRouter con ese modelo cargado */   cont.addEventListener(\"click\", function(e){     var p = e.target.closest(\".pick\");     if(!p || p.disabled) return;     var card = p.closest(\".panel\");     var modelo = p.getAttribute(\"data-modelo\");     var slug = p.getAttribute(\"data-slug\");     var color = card.style.getPropertyValue(\"--accent\");      /* marca visual de la tarjeta elegida */     cont.querySelectorAll(\".panel\").forEach(function(c){ c.classList.remove(\"chosen\"); });     card.classList.add(\"chosen\");     cont.classList.add(\"has-choice\");     $(\"eleccion\").className = \"eleccion show\";     $(\"eleccion\").innerHTML = 'Abriendo <b style=\"color:' + color + '\">' + esc(modelo) + '</b> en OpenRouter...';      /* redireccion: nueva pestania al chat de OpenRouter con ese modelo */     var url = \"https://openrouter.ai/chat?models=\" + encodeURIComponent(slug);     window.open(url, \"_blank\", \"noopener\");   });    /* ---------- utilidades ---------- */   function esc(s){     return String(s)       .replace(/&/g,\"&amp;\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\")       .replace(/\"/g,\"&quot;\");   }    function mdToHtml(src){     var BT = String.fromCharCode(96);     var text = String(src).replace(/\\r\\n/g,\"\\n\");     var fence = BT+BT+BT;     var parts = text.split(fence);     var html = \"\";     for(var i=0;i<parts.length;i++){       if(i % 2 === 1){         var code = parts[i].replace(/^[^\\n]*\\n/, \"\");         html += \"<pre><code>\" + esc(code.replace(/\\n$/,\"\")) + \"</code></pre>\";       } else {         html += renderInlineBlocks(parts[i], BT);       }     }     return html;   }    function renderInlineBlocks(block, BT){     var lines = block.split(\"\\n\");     var out = \"\", list = null, para = [];     function flushPara(){       if(para.length){ out += \"<p>\" + inline(para.join(\" \"), BT) + \"</p>\"; para = []; }     }     function closeList(){ if(list){ out += \"</\" + list + \">\"; list = null; } }     for(var i=0;i<lines.length;i++){       var t = lines[i].trim();       if(t === \"\"){ flushPara(); closeList(); continue; }       var h = t.match(/^(#{1,3})\\s+(.*)$/);       if(h){ flushPara(); closeList();         var lvl = h[1].length; out += \"<h\"+lvl+\">\" + inline(h[2],BT) + \"</h\"+lvl+\">\"; continue; }       if(/^>\\s?/.test(t)){ flushPara(); closeList();         out += \"<blockquote>\" + inline(t.replace(/^>\\s?/,\"\"),BT) + \"</blockquote>\"; continue; }       var ul = t.match(/^[-*]\\s+(.*)$/);       var ol = t.match(/^\\d+[.)]\\s+(.*)$/);       if(ul || ol){         flushPara();         var want = ul ? \"ul\" : \"ol\";         if(list !== want){ closeList(); list = want; out += \"<\"+want+\">\"; }         out += \"<li>\" + inline((ul?ul[1]:ol[1]),BT) + \"</li>\";         continue;       }       closeList();       para.push(t);     }     flushPara(); closeList();     return out;   }    function inline(s, BT){     var out = esc(s);     var codeRe = new RegExp(BT + \"([^\" + BT + \"]+)\" + BT, \"g\");     out = out.replace(codeRe, function(_,c){ return \"<code>\" + c + \"</code>\"; });     out = out.replace(/\\*\\*([^*]+)\\*\\*/g, \"<strong>$1</strong>\");     out = out.replace(/\\*([^*]+)\\*/g, \"<em>$1</em>\");     out = out.replace(/__([^_]+)__/g, \"<strong>$1</strong>\");     out = out.replace(/\\[([^\\]]+)\\]\\((https